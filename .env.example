# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_PROVIDER="postgresql"
DATABASE_URL="postgresql://refugiauser:refugiapassword@localhost:5432/refugia"
POSTGRES_USER="refugiauser"
POSTGRES_PASSWORD="refugiapassword"
POSTGRES_DB="refugia"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-here"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# In production (VPS):
# NEXTAUTH_URL="https://yourdomain.com"
# NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# ─── APIs Externas ─────────────────────────────────────────────────────────────
# Flow (Pagos)
FLOW_API_KEY=""
FLOW_SECRET=""
FLOW_BASE_URL="https://sandbox.flow.cl/api"

# Resend (Emails)
RESEND_API_KEY=""
EMAIL_FROM="Refugia <no-reply@refugia.cl>"

# Cron Jobs
CRON_SECRET="your-cron-secret"
